C {res.sym} -540 -400 0 0 {name=R24
value=1000Meg
footprint=1206
device=resistor
m=1}
C {vsource.sym} -540 -340 0 0 {name=VIN2 savecurrent=false
value=0}
C {lab_pin.sym} -460 -550 0 0 {name=p3 sig_type=std_logic lab=VSS




}
C {lab_pin.sym} -660 -750 2 0 {name=p11 sig_type=std_logic lab=VSS




}
C {code_shown.sym} 105 -1190 0 0 {name=MODEL only_toplevel=true
format="tcleval( @value )"
value="
.lib cornerMOShv.lib mos_tt_stat
.lib cornerMOSlv.lib mos_tt_stat
.lib cornerRES.lib res_typ
.lib cornerCAP.lib cap_typ

"}
C {code.sym} -160 -1200 0 0 {name=MonteCarlo_Tran_2026 only_toplevel=true 

value="
K1 L9 L11  0.7

.param mm_ok=1
.param mc_ok=1
.param temp  = 27
.param w1=5u
.param w2=10u
.param l1=0.5u
.param l2=1u
.param ng1=1
.param m1=20
.param m2=10
.param Coef=0.1
.save all
.control

let mc_runs = 200
let run = 0

shell rm MonteCarlo_Tran_10mars2026.csv

set curplot=new
set scratch=$curplot
setplot $scratch

dowhile run < mc_runs

tran 50p 2.2u

  meas tran t1 when v(vclk)=0.6 rise=19
  meas tran t2 when v(vclk)=0.6 rise=20
  let period = (t2 - t1)
  let freq = 1/period

print freq >> MonteCarlo_Tran_10mars2026.csv 

set run=$&run
set ac=$curplot
setplot $scratch

let out\{$run\}=\{$ac\}.vclk
let temp\{$run\}=\{$ac\}.time
setplot $ac
reset
let run=run+1
end

//plot \{$scratch\}.all vs \{$scratch\}.temp0 
//wrdata MonteCarlo_Tran_2026.csv  \{$scratch\}.freq
//echo 'Monte Carlo Simulation Completed.'
//echo 'Frequencies saved in MonteCarlo_Freq.csv'

write MonteCarlo_Tran_2026.raw
.endc
"}
