C {code.sym} -750 -1100 0 0 {name=NGSPICE_TRAN_10mars2026 only_toplevel=true 
value="
.param temp=27
.options rshunt =1e12
.param w1=5u
.param w2=10u
.param l1=0.5u
.param l2=1u
.param ng1=1
.param m1=20
.param m2=10
.param Coef=0.1
.save all
.control
 save all
* Transient simulation
op
tran 50p 12u
plot vclk 
//plot vout
//plot vout1 
plot i(Vmeas7)
plot i(Vmeas)
//plot vout2
plot Vp-Vn 

meas tran avg_current AVG I(VDD)  from=5u to=5.5u
let  power_VDD=3*avg_current
meas tran avg_current_1 AVG I(VDD1) from=5u to=5.5u
let  power_VDD1=1.2*avg_current_1
meas tran avg_current_2 AVG I(VDD2) from=5u to=5.5u
let  power_VDD2=1.2*avg_current_2
let total_power=power_VDD + power_VDD1 + power_VDD2

meas tran thigh TRIG v(vclk) VAL=1.08 RISE=39 TARG v(vclk) VAL=1.08 FALL=39
meas tran tlow TRIG  v(vclk)  VAL=0.12 FALL=39  TARG v(vclk) VAL=0.12 RISE=40

//meas tran thigh TRIG v(vclk) VAl=0.6 RISE=25 TARG v(vclk) VAl=0.6 FALL=25
//meas tran tlow  TRIG v(vclk) VAl=0.6 FALL=25 TARG v(vclk) VAl=0.6 RISE=26
  * rise time and fall time
meas tran t100 when v(vclk)=0.12 rise=25
meas tran t90  when  v(vclk)=1.08 rise=25

let RiseTime = t90 - t100

meas tran t90_f when v(vclk)=1.08 fall=25
meas tran t10_f when v(vclk)=0.12 fall=25

let FallTime = t10_f - t90_f

meas tran t1 when v(vclk)=0.6 rise=25
meas tran t2 when v(vclk)=0.6 rise=26
let period1 =(t2 - t1)
let freq1 =1/period1

meas tran t3 when v(vclk)=0.6 rise=27
let period2 =(t3 - t2)
let freq2 =1/period2

meas tran t4 when v(vclk)=0.6 rise=28
let period3 =(t4 - t3)
let freq3 =1/period3

meas tran t5 when v(vclk)=0.6 rise=29
let period4 =(t5 - t4)
let freq4 =1/period4

meas tran t6 when v(vclk)=0.6 rise=30
let period5 =(t6 - t5)
let freq5 =1/period5


meas tran t7 when v(vclk)=0.6 rise=31
let period6 =(t7 - t6)
let freq6 =1/period6

meas tran t8 when v(vclk)=0.6 rise=32
let period7 =(t8 - t7)
let freq7 =1/period7

meas tran t9 when v(vclk)=0.6 rise=33
let period8 =(t9 - t8)
let freq8 =1/period8

meas tran t10 when v(vclk)=0.6 rise=34
let period9 =(t10 - t9)
let freq9 =1/period9

meas tran t11 when v(vclk)=0.6 rise=35
let period10 =(t11 - t10)
let freq10 =1/period10


meas tran t12 when v(vclk)=0.6 rise=36
let period11 =(t12 - t11)
let freq11 =1/period11

meas tran t13 when v(vclk)=0.6 rise=37
let period12 =(t13 - t12)
let freq12 =1/period12

meas tran t14 when v(vclk)=0.6 rise=38
let period13 =(t14 - t13)
let freq13 =1/period13

meas tran t15 when v(vclk)=0.6 rise=39
let period14 =(t15 - t14)
let freq14 =1/period14

meas tran t16 when v(vclk)=0.6 rise=40
let period15 =(t16 - t15)
let freq15 =1/period15


meas tran t17 when v(vclk)=0.6 rise=41
let period16 =(t17 - t16)
let freq16 =1/period16

meas tran t18 when v(vclk)=0.6 rise=42
let period17 =(t18 - t17)
let freq17 =1/period17

meas tran t19 when v(vclk)=0.6 rise=43
let period18 =(t19 - t18)
let freq18 =1/period18


meas tran t20 when v(vclk)=0.6 rise=44
let period19 =(t20 - t19)
let freq19 =1/period19

meas tran t21 when v(vclk)=0.6 rise=54
let period20 =(t21 - t20)/10
let freq20 =1/period20


let duty_cycle =thigh/(period1)*100


print freq1
print freq2
print freq3
print freq4
print freq5
print freq6
print freq7
print freq8
print freq9
print freq10
print freq11
print freq12
print freq13
print freq14
print freq15
print freq16
print freq17
print freq18
print freq19
print freq20

print thigh 
print tlow
print RiseTime 
print FallTime
print duty_cycle
print total_power

 
 write clock_extractor_10mars2026.raw 
.endc
K1 L9 L11  0.7
"}
